{
  "name": "chkobba",
  "version": "1.0.0",
  "type": "module",
  "description": "A minimalist browser-based multiplayer implementation of the Tunisian card game Chkobba",
  "main": "dist/server/index.js",
  "scripts": {
    "dev": "tsx watch server/index.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "cd client && npm install && npm run build",
    "build:server": "tsc",
    "start": "node dist/server/index.js"
  },
  "keywords": [
    "chkobba",
    "card-game",
    "tunisian",
    "multiplayer",
    "socket.io"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.0.0",
    "@types/socket.io": "^3.0.1",
    "@types/uuid": "^10.0.0",
    "express": "^4.18.2",
    "socket.io": "^4.6.1",
    "typescript": "^5.4.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@flydotio/dockerfile": "^0.7.10",
    "tsx": "^4.21.0"
  }
}
